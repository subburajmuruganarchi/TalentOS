# =============================================================================
# TalentOS — Root environment template
# Copy to .env and fill in values. Per-app overrides live in apps/*/.env.example
# =============================================================================

# --- Shared ---
NODE_ENV=development

# --- MongoDB Atlas (local Docker uses infra/docker defaults) ---
MONGODB_URI=mongodb://talentos:talentos@localhost:27017/talentos?authSource=admin

# --- JWT (NestJS API) ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Supabase Storage ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=talentos-files

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=your-openai-api-key

# --- App URLs (local development) ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# --- Email (Phase 4+) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@talentos.app
