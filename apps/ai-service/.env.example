# TalentOS AI Service
APP_NAME=TalentOS AI Service
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

# MongoDB
MONGODB_URI=mongodb://talentos:talentos@localhost:27017/talentos?authSource=admin

# NestJS API (callbacks)
API_URL=http://localhost:3001
API_INTERNAL_SECRET=change-me-in-production

# LLM provider: openai | anthropic | ollama
LLM_PROVIDER=openai
LLM_TEMPERATURE=0

# OpenAI (default provider)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Ollama (optional, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings + MongoDB Vector Search
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CHUNK_SIZE=800
EMBEDDING_CHUNK_OVERLAP=120
VECTOR_COLLECTION_NAME=document_embeddings
VECTOR_INDEX_NAME=talentos_vector_index
VECTOR_SEARCH_ENABLED=true
VECTOR_NUM_CANDIDATES=100
VECTOR_SEARCH_LIMIT=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
